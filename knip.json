{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "kittynode-docs": {
      "entry": ["src/styles/custom.css"],
      "ignoreDependencies": ["sharp", "wrangler"]
    },
    "packages/app": {
      "entry": ["src/lib/components/ui/*/index.ts"],
      "ignoreUnresolved": ["^\\$app/.+"]
    },
    "kittynode-com": {
      "entry": ["src/lib/components/ui/*/index.ts"],
      "ignoreUnresolved": ["^\\$app/.+"]
    }
  }
}
